# API Keys — kendi anahtarlarınızı buraya yazın, dosyayı .env olarak kaydedin.

# ─── BELGE PARSE (zorunlu) ─────────────────────────────────────
# LlamaParse — PDF/DOCX/JPG → ham metin
# https://cloud.llamaindex.ai/
LLAMAPARSE_API_KEY=llx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ALAN EŞLEŞTİRME (zorunlu) ─────────────────────────────────
# MiniMax Global — alan eşleştirme
# https://www.minimax.io/
MINIMAX_API_KEY=
# Bazı endpoint'ler grup kimliği ister; konsoldan al
MINIMAX_GROUP_ID=
# Opsiyonel model override (varsayılan: MiniMax-Text-01)
# MINIMAX_MODEL=MiniMax-Text-01
